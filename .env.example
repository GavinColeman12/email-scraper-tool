# Required: for Google Maps business search
SEARCHAPI_KEY=

# Optional: paid email verification (only if you want to verify >500 emails/mo)
# ZeroBounce ($15 for 2000 emails) — https://www.zerobounce.net
ZEROBOUNCE_API_KEY=

# Optional: NeverBounce (recommended — 1,000 free verifications/month)
# https://www.neverbounce.com — ~$0.003/email after free tier
NEVERBOUNCE_API_KEY=

# Optional: Gmail OAuth — powers the 🔄 Sync from Gmail button on the
# dashboard (pulls real sends + bounces from your outbox into
# email_sends so the trend charts have data).
#
# LOCAL: point at the token.json file
GMAIL_CREDENTIALS_PATH=../reputation-audit-tool/credentials/token.json
#
# STREAMLIT CLOUD: files can't be mounted. Instead, set
# GMAIL_TOKEN_JSON to the full contents of token.json as a single-line
# JSON blob. Stash it via the app's Secrets UI (Manage app → Secrets).
# Example (your values will differ):
#   GMAIL_TOKEN_JSON = '{"token": "...", "refresh_token": "...", "client_id": "...", ...}'
# The token needs gmail.readonly scope (send/compose optional).
